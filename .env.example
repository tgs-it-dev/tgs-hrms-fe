# =============================================================================
# TGS HRMS — Environment Variable Reference
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — the app will throw on startup if these are missing
# ---------------------------------------------------------------------------

# Base URL of the backend REST API (no trailing slash)
VITE_API_BASE_URL=https://api.example.com

# Google OAuth 2.0 client ID (for Sign in with Google)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---------------------------------------------------------------------------
# Optional — sensible defaults apply when omitted
# ---------------------------------------------------------------------------

# Google Places API key (used by geofencing/address autocomplete)
VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Feature flags (set to "true" to enable)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_GEOFENCING=false
VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_USE_MOCK_POLICIES=true
